{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd InazumaLegacy && chmod +x mvnw && ./mvnw clean install -DskipTests"
  },
  "deploy": {
    "startCommand": "java -jar InazumaLegacy/target/*.jar",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}